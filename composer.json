{
    "name": "bytetcore/lalog",
    "version": "1.0.0",
    "description": "A robust Laravel SQL Query Logger that logs all database queries to files with rotation, performance metrics, and cross-database compatibility.",
    "keywords": [
        "laravel",
        "sql",
        "query",
        "log",
        "logging",
        "debug",
        "eloquent",
        "database",
        "performance"
    ],
    "type": "library",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "dovutuan",
            "email": "tuando.0598@gmail.com"
        }
    ],
    "support": {
        "email": "tuando.0598@gmail.com",
        "issues": "https://github.com/ByteTCore/lalog/issues",
        "wiki": "https://github.com/ByteTCore/lalog/wiki",
        "source": "https://github.com/ByteTCore/lalog",
        "docs": "https://github.com/ByteTCore/lalog"
    },
    "require": {
        "php": "^8.0",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "1.0",
        "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^9.5|^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Lalog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lalog\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lalog\\LalogServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "format": "vendor/bin/pint",
        "format-check": "vendor/bin/pint --test"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
